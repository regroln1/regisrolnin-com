---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const currentPath = Astro.url.pathname;
const isBlogArticle = currentPath.startsWith('/blog/') && currentPath !== '/blog/' && currentPath !== '/blog/glossaire';
---

<Layout
  title={isBlogArticle ? "Article en cours de rédaction — Régis Rolnin" : "Page introuvable — Régis Rolnin"}
  description={isBlogArticle ? "Cet article est en cours de rédaction. Inscrivez-vous à la newsletter pour être informé de sa parution." : "La page que vous cherchez n'existe pas."}
>
  <Header />

  <main class="pt-20">
    {isBlogArticle ? (
      <!-- Coming Soon — Article pas encore publié -->
      <section class="py-24 lg:py-32 bg-gradient-to-br from-gray-50 via-white to-emerald-50 min-h-[70vh] flex items-center">
        <div class="container mx-auto px-6">
          <div class="max-w-2xl mx-auto text-center">
            
            <!-- Icône -->
            <div class="w-20 h-20 bg-gradient-to-r from-emerald-500 to-teal-600 rounded-2xl flex items-center justify-center mx-auto mb-8">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
              </svg>
            </div>

            <!-- Titre -->
            <h1 class="text-3xl md:text-4xl font-bold text-navy-900 font-crimson mb-4">
              Cet article est en cours de rédaction
            </h1>

            <!-- Message -->
            <p class="text-lg text-gray-600 font-crimson mb-4 leading-relaxed">
              Vous êtes au bon endroit, mais cet article n'est pas encore publié.
              Il fait partie de notre plan de contenu et arrive bientôt.
            </p>

            <p class="text-gray-500 font-crimson mb-10">
              Inscrivez-vous à la newsletter pour être informé de sa parution.
            </p>

            <!-- Newsletter CTA -->
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-10">
              <h2 class="text-xl font-bold text-navy-900 font-crimson mb-2">
                Pap'AIA — La Newsletter
              </h2>
              <p class="text-sm text-gray-500 font-crimson mb-6">
                Des stratégies avancées, des outils testés, et des idées concrètes pour bâtir une entreprise solide et scalable.
              </p>
              
              <!-- Lien vers le formulaire SuiteDash ou section newsletter -->
              <a
                href="https://acces.regisrolnin.com/la-newsletter-papaia" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-emerald-500 to-teal-600 text-white font-semibold rounded-xl hover:from-emerald-600 hover:to-teal-700 transition-all shadow-md hover:shadow-lg"
              >
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                Je m'inscris
              </a>
            </div>

            <!-- Retour -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="/blog"
                class="inline-flex items-center px-5 py-2.5 text-emerald-600 hover:text-emerald-800 font-medium font-crimson transition-colors"
              >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Voir tous les articles
              </a>
              <a
                href="/"
                class="inline-flex items-center px-5 py-2.5 text-gray-500 hover:text-gray-700 font-medium font-crimson transition-colors"
              >
                Retour à l'accueil
              </a>
            </div>

          </div>
        </div>
      </section>
    ) : (
      <!-- 404 classique — Page introuvable -->
      <section class="py-24 lg:py-32 bg-gradient-to-br from-gray-50 via-white to-blue-50 min-h-[70vh] flex items-center">
        <div class="container mx-auto px-6">
          <div class="max-w-2xl mx-auto text-center">
            
            <div class="text-8xl font-bold text-gray-200 font-crimson mb-6">
              404
            </div>

            <h1 class="text-3xl md:text-4xl font-bold text-navy-900 font-crimson mb-4">
              Page introuvable
            </h1>

            <p class="text-lg text-gray-600 font-crimson mb-10 leading-relaxed">
              La page que vous cherchez n'existe pas ou a été déplacée.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="/"
                class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-600 to-purple-600 text-white font-semibold rounded-xl hover:from-blue-700 hover:to-purple-700 transition-all shadow-md hover:shadow-lg"
              >
                Retour à l'accueil
              </a>
              <a
                href="/blog"
                class="inline-flex items-center px-6 py-3 border border-gray-300 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 transition-colors"
              >
                Voir le blog
              </a>
            </div>

          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>
